# Copy this file to .env and fill in your values
# Never commit .env to version control

FLASK_ENV=production

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.0/24,.example.com
TRUST_PROXY_HEADERS=True
TRUSTED_PROXY_HOPS=1
ALLOW_INSECURE_LOCAL_HTTP=False

# Multi-college tenancy
DEFAULT_COLLEGE_CODE=MAIN
MULTI_COLLEGE_ROOT_DOMAIN=example.com
PUBLIC_BASE_URL=https://portal.example.com

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=smart_attendance
DB_PASSWORD=replace-with-db-password
DB_NAME=smart_attendance
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=300
DB_POOL_PRE_PING=True

# Email (Gmail App Password or provider SMTP)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your_email@example.com
MAIL_PASSWORD=replace-with-mail-password

# Attendance / face recognition
LOW_ATTENDANCE_THRESHOLD=75
FACE_RECOGNITION_TOLERANCE=0.5
LIVENESS_STATE_TTL_SECONDS=600

# AI assistant
GROQ_API_KEY=replace-with-groq-api-key

# Rate limiter — Redis recommended for production
RATELIMIT_STORAGE_URI=redis://127.0.0.1:6379/0

# Uploads — keep these outside public static
UPLOAD_FOLDER=/absolute/path/to/static/uploads/faces
PRIVATE_UPLOAD_FOLDER=/absolute/path/to/private/uploads
CONTENT_UPLOAD_FOLDER=/absolute/path/to/private/uploads/content
LIBRARY_UPLOAD_FOLDER=/absolute/path/to/private/uploads/library
ASSIGNMENT_UPLOAD_FOLDER=/absolute/path/to/private/uploads/assignment_submissions
MAX_CONTENT_LENGTH=10485760

# Logging
LOG_LEVEL=INFO
LOG_DIR=/absolute/path/to/app/logs

# Gunicorn
GUNICORN_BIND=0.0.0.0:5050
GUNICORN_WORKERS=4
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=120
GUNICORN_GRACEFUL_TIMEOUT=30
GUNICORN_KEEPALIVE=5
GUNICORN_MAX_REQUESTS=1000
GUNICORN_MAX_REQUESTS_JITTER=100
GUNICORN_ACCESSLOG=-
GUNICORN_ERRORLOG=-
FORWARDED_ALLOW_IPS=127.0.0.1
